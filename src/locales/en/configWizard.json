{
  "configWizard": {
    "channelSteps": {
      "whatsapp": [
        "1. Run: openclaw channels login --channel whatsapp",
        "2. In allowFrom add allowed phone numbers (E.164, e.g. +86138...)"
      ],
      "telegram": [
        "1. In @BotFather send /newbot to get a Bot Token",
        "2. Use @userinfobot to get your User ID (for allowFrom)",
        "3. Or CLI: openclaw channels add --channel telegram --token <token>"
      ],
      "discord": [
        "1. Create an app in the Discord developer portal and get a Bot Token",
        "2. Enable Message Content Intent and invite the bot to your server"
      ],
      "slack": [
        "1. Create an app in Slack API",
        "2. Configure OAuth and the Bot Token"
      ],
      "imessage": [
        "1. Requires macOS and the imsg CLI bridge",
        "2. Fill allowed Apple ID or phone number"
      ],
      "signal": [
        "1. Install signal-cli and register/link your number",
        "2. Configure allowFrom list"
      ],
      "msteams": [
        "1. Register an app in Azure portal and create the Bot",
        "2. Configure Bot Framework credentials"
      ],
      "googlechat": [
        "1. Create a Chat API app in Google Cloud Console",
        "2. Configure Service Account JSON"
      ],
      "mattermost": [
        "1. Create a Bot account in Mattermost",
        "2. Get Bot Token and server URL"
      ],
      "matrix": [
        "1. Create a Matrix bot account",
        "2. Get Access Token and Homeserver URL"
      ],
      "irc": [
        "1. Configure IRC server address and channel",
        "2. Set bot nickname and auth"
      ],
      "feishu": [],
      "line": [
        "1. Create a Messaging API Channel in LINE Developers",
        "2. Get Channel Access Token"
      ],
      "nostr": [
        "1. Generate Nostr key pair (nsec/npub)",
        "2. Configure relay list"
      ],
      "twitch": [
        "1. Register an app in Twitch developer portal",
        "2. Get OAuth Token and channel name"
      ],
      "bluebubbles": [
        "1. Install BlueBubbles Server on macOS",
        "2. Configure API URL and password"
      ]
    },
